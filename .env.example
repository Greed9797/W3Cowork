# API Configuration 
# Required: Set your API authentication token 
# ANTHROPIC_AUTH_TOKEN=your_api_key_here 
 
# # Optional: Custom API endpoint 
# ANTHROPIC_BASE_URL=https://openrouter.ai/api 
 
# # Optional: Model selection 
# CLAUDE_MODEL=anthropic/claude-sonnet-4.5 
 
# Optional: Custom Claude Code CLI path
# IMPORTANT: Use forward slashes (/) on Windows, not backslashes (\)
# CLAUDE_CODE_PATH=C:/Users/yourname/AppData/Roaming/npm/node_modules/@anthropic-ai/claude-code/cli.js

# === Paperclip HTTP Adapter (W3 Sites Agency pipeline) ===
# Enable/disable the in-process HTTP adapter that exposes the 7 pipeline agents
# (agent-1..agent-7) to an external Paperclip orchestrator.
# ENABLE_PAPERCLIP_ADAPTER=true

# Bind port and host. Default 127.0.0.1:3200 (loopback only).
# Set host to 0.0.0.0 only if Paperclip runs in Docker on the same machine
# or on another host you trust.
# PAPERCLIP_ADAPTER_PORT=3200
# PAPERCLIP_ADAPTER_HOST=127.0.0.1

# Legacy subprocess backend override. The Paperclip Pipeline settings tab now
# stores the preferred backend in app config: SDK (default), CLI claude,
# CLI codex, or CLI pi. This env var remains for older local setups.
# PAPERCLIP_AGENT_BINARY=claude

# Optional: explicit absolute path to the claude binary if it is not on PATH.
# PAPERCLIP_CLAUDE_BIN=/Users/you/.local/bin/claude

# Optional: explicit absolute paths for additional CLI backends.
# PAPERCLIP_CODEX_BIN=/opt/homebrew/bin/codex
# PAPERCLIP_PI_BIN=/Users/you/open-cowork/node_modules/.bin/pi

# Optional: Claude Code permissions/tooling used by the CLI claude backend.
# PAPERCLIP_ALLOWED_TOOLS=WebSearch,Read,Write,Edit,MultiEdit,Bash,Grep,Glob,LS
# PAPERCLIP_PERMISSION_MODE=auto

# Per-task timeout (ms). Default 600000 (10 minutes).
# PAPERCLIP_TASK_TIMEOUT_MS=600000

# Manual trigger response timeout (ms). Default 180000 (3 minutes). Increase
# for long UI-triggered runs; timeout cancels the adapter task instead of
# leaving the Settings modal pending.
# PAPERCLIP_TRIGGER_TIMEOUT_MS=180000

# Optional helpers used by individual pipeline skills:
# GOOGLE_MAPS_API_KEY=
# CALENDLY_TOKEN=
